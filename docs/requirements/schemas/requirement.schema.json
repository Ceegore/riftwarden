{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://riftwarden.local/schemas/requirement.schema.json",
  "title": "Riftwarden Requirement",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "title",
    "statement",
    "norm",
    "category",
    "source",
    "ownerPhases",
    "verification",
    "relatedNormIds",
    "relatedScreenIds",
    "status"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^REQ-(PRODUCT|CONTENT|SIM|UX|SAVE|A11Y|PERF|SECURITY|ANDROID|IOS|STORE|QA)-[0-9]{4}$"
    },
    "title": {
      "type": "string",
      "minLength": 3
    },
    "statement": {
      "type": "string",
      "minLength": 10
    },
    "norm": {
      "enum": [
        "MUST",
        "MUST_NOT",
        "SHOULD",
        "MAY"
      ]
    },
    "category": {
      "enum": [
        "Product",
        "Content",
        "Sim",
        "UX",
        "Save",
        "A11y",
        "Perf",
        "Security",
        "Android",
        "iOS",
        "Store",
        "QA"
      ]
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sourceId",
        "chapter",
        "section",
        "locator",
        "quoteHash",
        "originalExcerpt"
      ],
      "properties": {
        "sourceId": {
          "type": "string"
        },
        "chapter": {
          "type": "integer",
          "minimum": 1,
          "maximum": 87
        },
        "section": {
          "type": [
            "string",
            "null"
          ]
        },
        "locator": {
          "type": "string",
          "minLength": 1
        },
        "quoteHash": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "originalExcerpt": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "ownerPhases": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^PHASE-(0[0-9]|[1-4][0-9])$"
      }
    },
    "verification": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "type",
          "plannedPhase",
          "testIds"
        ],
        "properties": {
          "type": {
            "enum": [
              "unit",
              "property",
              "golden",
              "integration",
              "e2e",
              "visual",
              "native",
              "manual",
              "review",
              "static"
            ]
          },
          "plannedPhase": {
            "type": "string",
            "pattern": "^PHASE-(0[0-9]|[1-4][0-9])$"
          },
          "testIds": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "numericConstraints": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "relatedNormIds": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^NORM-[0-9]{3}$"
      }
    },
    "relatedScreenIds": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string"
      }
    },
    "status": {
      "enum": [
        "planned",
        "implemented",
        "verified",
        "blocked",
        "deferred_by_spec"
      ]
    },
    "notes": {
      "type": [
        "string",
        "null"
      ]
    }
  }
}
