{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://riftwarden.local/schemas/traceability.schema.json",
  "title": "Riftwarden Traceability Matrix",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "links"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "links": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "requirementId",
          "testIds",
          "phaseIds",
          "screenIds",
          "normIds"
        ],
        "properties": {
          "requirementId": {
            "type": "string"
          },
          "testIds": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string"
            }
          },
          "phaseIds": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string"
            }
          },
          "screenIds": {
            "type": "array",
            "uniqueItems": true,
            "items": {
              "type": "string"
            }
          },
          "normIds": {
            "type": "array",
            "uniqueItems": true,
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
