{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://riftwarden.local/schemas/requirements-index.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "files"],
  "properties": {
    "schemaVersion": {"const": 1},
    "files": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^docs/requirements/requirements/[a-z0-9-]+\\.json$"
      }
    }
  }
}
