{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://riftwarden.local/schemas/external-decisions.schema.json",
  "title": "Riftwarden External Decisions",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "decisions"],
  "properties": {
    "schemaVersion": {"const": 1},
    "decisions": {
      "type": "array",
      "minItems": 7,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "key", "owner", "status", "developmentDefault", "value", "blockingGates", "recommendedClosure", "validationRule", "evidenceLinks"],
        "properties": {
          "id": {"type": "string", "pattern": "^EXT-[A-Z0-9]+(?:-[A-Z0-9]+)*-[0-9]{3}$"},
          "key": {"enum": ["PUBLISHER_LEGAL_NAME", "SUPPORT_EMAIL", "SUPPORT_URL", "PRIVACY_URL", "COPYRIGHT_YEAR", "PRICE_TIER", "PACKAGE_ID_CONFIRMATION"]},
          "owner": {"type": "string", "minLength": 1},
          "status": {"enum": ["pending", "confirmed", "rejected", "superseded"]},
          "developmentDefault": {},
          "value": {},
          "blockingGates": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "pattern": "^G(0[0-9]|[1-4][0-9])$"}},
          "recommendedClosure": {"type": "string", "minLength": 10},
          "validationRule": {"type": "object"},
          "evidenceLinks": {"type": "array", "items": {"type": "string"}}
        }
      }
    }
  }
}
