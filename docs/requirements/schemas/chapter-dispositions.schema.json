{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://riftwarden.local/schemas/chapter-dispositions.schema.json",
  "$defs": {
    "chapter": {
      "type": "object",
      "additionalProperties": false,
      "required": ["chapter", "disposition", "reason", "reviewStatus", "reviewedBy", "reviewedAt"],
      "properties": {
        "chapter": {"type": "integer", "minimum": 1, "maximum": 87},
        "disposition": {"const": "context_only"},
        "reason": {"type": "string", "minLength": 20},
        "reviewStatus": {"enum": ["verified", "requires_review", "rejected"]},
        "reviewedBy": {"type": ["string", "null"]},
        "reviewedAt": {"type": ["string", "null"], "format": "date-time"}
      }
    }
  },
  "oneOf": [
    {
      "type": "object",
      "required": ["schemaVersion", "chapters"],
      "properties": {
        "schemaVersion": {"const": 1},
        "chapters": {"type": "array", "items": {"$ref": "#/$defs/chapter"}}
      }
    },
    {
      "type": "object",
      "required": ["schemaVersion", "files"],
      "properties": {
        "schemaVersion": {"const": 1},
        "files": {"type": "array", "minItems": 1, "items": {"type": "string"}}
      }
    }
  ]
}
