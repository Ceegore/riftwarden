{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://riftwarden.local/schemas/normalization-ledger.schema.json",
  "$defs": {
    "record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "topic",
        "canonicalRule",
        "status",
        "authorityPriority",
        "authorityReferences",
        "affectedRequirementIds",
        "supersededStatements",
        "reviewStatus",
        "reviewedBy",
        "reviewedAt"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^NORM-[0-9]{3}$"
        },
        "topic": {
          "type": "string",
          "minLength": 1
        },
        "canonicalRule": {
          "type": "string",
          "minLength": 10
        },
        "status": {
          "enum": [
            "active",
            "superseded"
          ]
        },
        "authorityPriority": {
          "type": "integer",
          "minimum": 1,
          "maximum": 7
        },
        "authorityReferences": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "affectedRequirementIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "supersededStatements": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "reviewStatus": {
          "enum": [
            "requires_review",
            "verified",
            "rejected"
          ]
        },
        "reviewedBy": {
          "type": [
            "string",
            "null"
          ]
        },
        "reviewedAt": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        }
      }
    }
  },
  "oneOf": [
    {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "authorityOrder",
        "records"
      ],
      "properties": {
        "schemaVersion": {
          "const": 1
        },
        "authorityOrder": {
          "type": "array",
          "minItems": 7,
          "maxItems": 7,
          "items": {
            "type": "string"
          }
        },
        "records": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/record"
          }
        }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "authorityOrder",
        "files"
      ],
      "properties": {
        "schemaVersion": {
          "const": 1
        },
        "authorityOrder": {
          "type": "array",
          "minItems": 7,
          "maxItems": 7,
          "items": {
            "type": "string"
          }
        },
        "files": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        }
      }
    }
  ]
}
