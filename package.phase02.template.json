{
  "name": "riftwarden-auto-rpg-roguelite",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@__PNPM_VERSION__",
  "engines": {
    "node": "__NODE_ENGINE_RANGE__",
    "pnpm": "__PNPM_ENGINE_RANGE__"
  },
  "scripts": {
    "dev": "node tools/env/validate.mjs --channel dev && vite --mode dev",
    "build": "pnpm build:release",
    "build:dev": "node tools/build/run-build.mjs dev",
    "build:qa": "node tools/build/run-build.mjs qa",
    "build:release": "node tools/build/run-build.mjs release",
    "preview": "vite preview --host 127.0.0.1",
    "typecheck": "tsc -b --pretty false",
    "lint": "eslint . --max-warnings 0 && node tools/lint/check-todos.mjs",
    "lint:fix": "eslint . --fix --max-warnings 0 && node tools/lint/check-todos.mjs",
    "lint:negative": "node tools/lint/run-negative-fixtures.mjs",
    "format": "pnpm lint:fix && node tools/format/write-format.mjs",
    "format:check": "node tools/format/check-format.mjs && pnpm lint",
    "test:unit": "vitest run --project unit",
    "test:sim": "vitest run --project simulation",
    "test:integration": "vitest run --project integration",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install chromium firefox webkit",
    "test:tooling": "node --test tests/tooling/*.test.mjs",
    "toolchain:resolve": "node tools/toolchain/resolve-versions.mjs",
    "toolchain:apply": "node tools/toolchain/apply-freeze.mjs",
    "toolchain:verify": "node tools/toolchain/verify-freeze.mjs",
    "toolchain:licenses": "node tools/toolchain/verify-licenses.mjs",
    "toolchain:postinstall-audit": "node tools/toolchain/audit-postinstall.mjs",
    "toolchain:capture-native": "node tools/toolchain/capture-native-toolchains.mjs",
    "verify:phase02": "node tools/repo/verify-phase02.mjs"
  },
  "dependencies": {
    "react": "__VERSION__",
    "react-dom": "__VERSION__",
    "zustand": "__VERSION__",
    "motion": "__VERSION__",
    "pixi.js": "__VERSION__",
    "zod": "__VERSION__",
    "@capacitor/core": "__VERSION__",
    "@capacitor/android": "__VERSION__",
    "@capacitor/ios": "__VERSION__",
    "@capacitor/app": "__VERSION__",
    "@capacitor/filesystem": "__VERSION__",
    "@capacitor/preferences": "__VERSION__",
    "@capacitor/haptics": "__VERSION__",
    "@capacitor/screen-orientation": "__VERSION__",
    "@capacitor/splash-screen": "__VERSION__",
    "@capacitor/browser": "__VERSION__"
  },
  "devDependencies": {
    "@capacitor/cli": "__VERSION__",
    "typescript": "__VERSION__",
    "vite": "__VERSION__",
    "@vitejs/plugin-react": "__VERSION__",
    "tailwindcss": "__VERSION__",
    "@tailwindcss/vite": "__VERSION__",
    "eslint": "__VERSION__",
    "@eslint/js": "__VERSION__",
    "typescript-eslint": "__VERSION__",
    "eslint-plugin-react-hooks": "__VERSION__",
    "eslint-plugin-react-refresh": "__VERSION__",
    "vitest": "__VERSION__",
    "@vitest/coverage-v8": "__VERSION__",
    "@playwright/test": "__VERSION__",
    "@types/react": "__VERSION__",
    "@types/react-dom": "__VERSION__",
    "@types/node": "__VERSION__"
  },
  "pnpm": {
    "onlyBuiltDependencies": [],
    "ignoredBuiltDependencies": []
  }
}
