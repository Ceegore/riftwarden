{
  "name": "riftwarden-auto-rpg-roguelite",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10.0.0 <11"
  },
  "scripts": {
    "dev": "node tools/env/validate.mjs --channel dev && vite --mode dev",
    "build": "pnpm build:release",
    "build:dev": "node tools/build/run-build.mjs dev",
    "build:qa": "node tools/build/run-build.mjs qa",
    "build:release": "node tools/build/run-build.mjs release",
    "preview": "vite preview --host 127.0.0.1",
    "typecheck": "tsc -b --pretty false",
    "lint": "eslint . --max-warnings 0 && node tools/lint/check-todos.mjs",
    "lint:fix": "eslint . --fix --max-warnings 0 && node tools/lint/check-todos.mjs",
    "lint:negative": "node tools/lint/run-negative-fixtures.mjs",
    "format": "pnpm lint:fix && node tools/format/write-format.mjs",
    "format:check": "node tools/format/check-format.mjs && pnpm lint",
    "test:unit": "vitest run --project unit",
    "test:sim": "vitest run --project simulation",
    "test:integration": "vitest run --project integration",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install chromium firefox webkit",
    "test:tooling": "node --test tests/tooling/*.test.mjs",
    "toolchain:resolve": "node tools/toolchain/resolve-versions.mjs",
    "toolchain:apply": "node tools/toolchain/apply-freeze.mjs",
    "toolchain:verify": "node tools/toolchain/verify-freeze.mjs",
    "toolchain:licenses": "node tools/toolchain/verify-licenses.mjs",
    "toolchain:postinstall-audit": "node tools/toolchain/audit-postinstall.mjs",
    "toolchain:capture-native": "node tools/toolchain/capture-native-toolchains.mjs",
    "verify:phase02": "node tools/repo/verify-phase02.mjs",
    "ci:verify-workflows": "node tools/ci/verify-workflows.mjs",
    "ci:gate-map": "node tools/ci/create-gate-map.mjs",
    "ci:assert-results": "node tools/ci/assert-needs-results.mjs",
    "ci:verify-branch-evidence": "node tools/ci/verify-branch-protection-evidence.mjs",
    "build:manifest": "node tools/build/create-manifest.mjs",
    "build:hash-tree": "node tools/build/hash-tree.mjs",
    "deps:capture": "node tools/deps/capture.mjs",
    "deps:report": "node tools/deps/report.mjs",
    "deps:sbom": "node tools/deps/create-cyclonedx.mjs",
    "deps:diff": "node tools/deps/diff.mjs",
    "security:audit": "node tools/security/run-audit.mjs",
    "security:secrets": "node tools/security/scan-secrets.mjs",
    "security:artifact-paths": "node tools/security/check-artifact-allowlist.mjs",
    "test:phase03-tooling": "node --test tests/tooling/phase03/*.test.mjs",
    "verify:phase03": "node tools/repo/verify-phase03.mjs",
    "verify:repo": "node tools/repo/verify-root.mjs",
    "check:text-normalization": "node tools/repo/check-text-normalization.mjs",
    "check:file-length": "node tools/check-file-length.mjs",
    "test:repo": "node --test tests/unit/repo/*.test.mjs",
    "requirements:validate": "node tools/requirements/validate.mjs --mode=gate",
    "cap:sync": "pnpm build:release && cap sync",
    "native:env": "node tools/native/report-environment.mjs > artifacts/native/environment.json",
    "native:hash": "node tools/native/hash-tree.mjs . android ios capacitor.config.ts > artifacts/native/tree.json",
    "verify:native-config": "node tools/native/verify-config.mjs",
    "verify:plugin-contracts": "node tools/native/verify-plugin-contracts.mjs",
    "android:debug": "node tools/native/run-gradle.mjs assembleDebug",
    "android:release-manifest": "node tools/native/run-gradle.mjs processReleaseMainManifest",
    "verify:phase04": "node tools/native/verify-g04.mjs"
  },
  "dependencies": {
    "react": "19.2.8",
    "react-dom": "19.2.8",
    "zustand": "5.0.14",
    "motion": "12.42.2",
    "pixi.js": "8.19.0",
    "zod": "4.4.3",
    "@capacitor/core": "8.4.2",
    "@capacitor/android": "8.4.2",
    "@capacitor/ios": "8.4.2",
    "@capacitor/app": "8.1.1",
    "@capacitor/filesystem": "8.1.2",
    "@capacitor/preferences": "8.0.1",
    "@capacitor/haptics": "8.0.2",
    "@capacitor/screen-orientation": "8.0.1",
    "@capacitor/splash-screen": "8.0.2",
    "@capacitor/browser": "8.0.4"
  },
  "devDependencies": {
    "@capacitor/cli": "8.4.2",
    "typescript": "5.9.3",
    "vite": "8.1.5",
    "@vitejs/plugin-react": "6.0.4",
    "tailwindcss": "4.3.3",
    "@tailwindcss/vite": "4.3.3",
    "eslint": "10.7.0",
    "@eslint/js": "10.0.1",
    "typescript-eslint": "8.65.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "vitest": "4.1.10",
    "@vitest/coverage-v8": "4.1.10",
    "@playwright/test": "1.61.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/node": "22.20.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [],
    "ignoredBuiltDependencies": []
  }
}
