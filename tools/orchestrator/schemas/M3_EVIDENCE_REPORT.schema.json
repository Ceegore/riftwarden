{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "M3_EVIDENCE_REPORT.schema.json",
  "title": "M3 Evidence Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "report_id",
    "project_id",
    "phase_id",
    "work_package_id",
    "request_id",
    "status",
    "repository",
    "changed_files",
    "deliverables",
    "test_results",
    "commands",
    "decisions_within_authority",
    "deviations",
    "risks",
    "artifacts",
    "scope_self_check",
    "finalized_at"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "report_id": {
      "type": "string",
      "minLength": 1
    },
    "project_id": {
      "type": "string",
      "minLength": 1
    },
    "phase_id": {
      "type": "string",
      "minLength": 1
    },
    "work_package_id": {
      "type": "string",
      "minLength": 1
    },
    "request_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "enum": [
        "COMPLETE",
        "PARTIAL",
        "BLOCKED",
        "FAILED"
      ]
    },
    "repository": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "branch",
        "start_commit",
        "end_commit",
        "tree_hash",
        "dirty"
      ],
      "properties": {
        "branch": {
          "type": "string"
        },
        "start_commit": {
          "type": "string"
        },
        "end_commit": {
          "type": [
            "string",
            "null"
          ]
        },
        "tree_hash": {
          "type": "string"
        },
        "dirty": {
          "type": "boolean"
        }
      }
    },
    "changed_files": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "path",
          "change_type",
          "sha256"
        ],
        "properties": {
          "path": {
            "type": "string"
          },
          "change_type": {
            "enum": [
              "added",
              "modified",
              "deleted",
              "renamed",
              "generated"
            ]
          },
          "sha256": {
            "type": [
              "string",
              "null"
            ]
          },
          "purpose": {
            "type": "string"
          }
        }
      }
    },
    "deliverables": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "status",
          "evidence"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "status": {
            "enum": [
              "met",
              "partial",
              "not_met",
              "not_applicable"
            ]
          },
          "evidence": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "test_results": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "command",
          "executed",
          "exit_code",
          "status",
          "artifact_path",
          "artifact_sha256",
          "commit_or_tree"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "command": {
            "type": "string"
          },
          "working_directory": {
            "type": "string"
          },
          "executed": {
            "type": "boolean"
          },
          "exit_code": {
            "type": [
              "integer",
              "null"
            ]
          },
          "status": {
            "enum": [
              "passed",
              "failed",
              "skipped",
              "not_applicable"
            ]
          },
          "reason": {
            "type": [
              "string",
              "null"
            ]
          },
          "artifact_path": {
            "type": [
              "string",
              "null"
            ]
          },
          "artifact_sha256": {
            "type": [
              "string",
              "null"
            ]
          },
          "commit_or_tree": {
            "type": [
              "string",
              "null"
            ]
          },
          "duration_ms": {
            "type": [
              "integer",
              "null"
            ]
          }
        }
      }
    },
    "commands": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "command_id",
          "exit_code",
          "status"
        ],
        "properties": {
          "command_id": {
            "type": "string"
          },
          "exit_code": {
            "type": [
              "integer",
              "null"
            ]
          },
          "status": {
            "type": "string"
          },
          "artifact_path": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    },
    "decisions_within_authority": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "decision",
          "rationale"
        ],
        "properties": {
          "decision": {
            "type": "string"
          },
          "rationale": {
            "type": "string"
          },
          "affected_paths": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "deviations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "description",
          "impact",
          "authorization"
        ],
        "properties": {
          "description": {
            "type": "string"
          },
          "impact": {
            "type": "string"
          },
          "authorization": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "severity",
          "description"
        ],
        "properties": {
          "severity": {
            "enum": [
              "P0",
              "P1",
              "P2",
              "P3",
              "P4"
            ]
          },
          "description": {
            "type": "string"
          },
          "mitigation": {
            "type": "string"
          }
        }
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "type",
          "path",
          "sha256"
        ],
        "properties": {
          "type": {
            "type": "string"
          },
          "path": {
            "type": "string"
          },
          "sha256": {
            "type": "string"
          }
        }
      }
    },
    "scope_self_check": {
      "type": "object",
      "required": [
        "within_scope",
        "unexpected_paths",
        "budget_exceeded",
        "tests_weakened",
        "new_dependencies"
      ],
      "properties": {
        "within_scope": {
          "type": "boolean"
        },
        "unexpected_paths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "budget_exceeded": {
          "type": "boolean"
        },
        "tests_weakened": {
          "type": "boolean"
        },
        "new_dependencies": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "finalized_at": {
      "type": "string"
    }
  }
}
