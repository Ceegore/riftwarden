# === Riftwarden repository gitignore ===
# Scope: the game repo tracks only authoritative sources + game code + orchestration code.
# Large planning archives and orchestration state are deliberately excluded.

# --- Planning archives (kept on disk, not in git history) ---
/Phasen/
/backup/
/Meldungen/
/.orchestration_source/
/.zcode/

# --- Duplicate/older source copies at repo root (canonical copies live in docs/source/) ---
/Riftwarden_Auto_RPG_Roguelite_GDD_V*.docx
/Riftwarden_Entwicklungsplan*.docx

# --- Orchestrator runtime state (regenerated from files; large/mutable) ---
/.orchestrator/logs/
/.orchestrator/artifacts/
/.orchestrator/checkpoints/
/.orchestrator/locks/
/.orchestrator/mailbox/
/.orchestrator/sessions/
# NOTE: top-level state JSON/YAML (.orchestrator/*.json, *.yaml) ARE tracked.

# --- Secrets ---
.env
.env.*
*.pem
*.key
secrets.json
credentials.json

# --- Node ---
node_modules/
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*
dist/
build/
coverage/
.nyc_output/
*.tsbuildinfo

# --- Capacitor / mobile ---
/ios/App/App/public
/android/app/src/main/assets/public
/android/app/build/
/android/build/
/android/.gradle/
/ios/App/Pods/
/ios/App/build/
DerivedData/
*.apk
*.aab
*.ipa

# --- Python (orchestrator tooling) ---
__pycache__/
*.py[cod]
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# --- OS / editor ---
.DS_Store
Thumbs.db
desktop.ini
.idea/
.vscode/
*.swp
*~

# --- Generated artifacts (tracked explicitly when needed) #
generated/README_DO_NOT_TRACK.txt
